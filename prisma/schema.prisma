// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 用户表
model User {
  id          String   @id @default(uuid())
  username    String   @unique // 用户名（支持中文）
  email       String   @unique
  password    String
  inviteCode  String   @unique // 专属邀请码
  avatarUrl   String?  // 头像 URL（可选）
  partnerId   String?  @unique
  partner     User?    @relation("PartnerRelation", fields: [partnerId], references: [id])
  partnerOf   User?    @relation("PartnerRelation")
  // 配对时间
  pairedAt          DateTime? // 配对开始时间
  // 取消配对冷静期相关字段
  breakupInitiated  Boolean   @default(false) // 是否发起了解除配对
  breakupAt         DateTime? // 发起解除配对的时间
  // 归档相关字段
  archivedPartnerId String?   // 已归档的伴侣 ID
  archivedAt        DateTime? // 归档时间
  archivedPosts     Post[]    @relation("ArchivedPosts")
  sentRequests     PairRequest[] @relation("SentRequests")
  receivedRequests PairRequest[] @relation("ReceivedRequests")
  posts       Post[]
  comments    Comment[]    // 用户发表的评论
  notifications    Notification[] @relation("NotificationReceiver") // 收到的通知
  sentNotifications  Notification[] @relation("NotificationSender")  // 发送的通知
  paymentOrders    PaymentOrder[] // 支付订单
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  lastLoginAt DateTime? // 最后登录时间
  sessions    SessionToken[] // 关联的 session token
}

// Session Token 表 - 用于自动登录
model SessionToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([token])
  @@index([userId])
}

// 配对请求表
model PairRequest {
  id          String   @id @default(uuid())
  senderId    String
  receiverId  String
  status      String   @default("pending") // pending, accepted, rejected
  sender      User     @relation("SentRequests", fields: [senderId], references: [id])
  receiver    User     @relation("ReceivedRequests", fields: [receiverId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([senderId, receiverId]) // 同一对用户之间只能有一个请求
}

// 分享表 - 移除唯一约束，允许多次分享
model Post {
  id        String        @id @default(uuid())
  userId    String
  user      User          @relation(fields: [userId], references: [id])
  date      String        // 日期格式：YYYY-MM-DD
  title     String?       // 标题（可选）
  imageUrl  String?       // 图片 URL（可选）
  text      String?       // 文字内容（可选）
  // 位置相关字段（地图打卡）
  latitude    Float?      // 纬度
  longitude   Float?      // 经度
  location    String?     // 位置名称（用户手动输入）
  // 归档相关字段
  archivedAt    DateTime? // 归档时间（null=未归档）
  archivedBy    String?   // 归档操作人 userId
  archivedUser  User?     @relation("ArchivedPosts", fields: [archivedBy], references: [id])
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([userId, date]) // 添加索引以便查询
  @@index([archivedAt])   // 归档时间索引
  comments  Comment[]     // 关联评论
  notifications Notification[] // 关联通知
}

// 主题表 - 已废弃，保留但不再生成新主题
model Theme {
  id        String   @id @default(uuid())
  text      String   // 主题文字
  category  String   // 主题分类：daily/memory/fun
  isActive  Boolean  @default(false) // 默认不激活
  createdAt DateTime @default(now())
}

// 评论表 - 支持嵌套评论
model Comment {
  id          String    @id @default(cuid())
  postId      String    // 所属分享 ID
  userId      String    // 评论者 ID
  parentId    String?   // 父评论 ID（用于嵌套回复）
  content     String    // 评论内容
  imageUrl    String?   // 评论图片 URL（可选）
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  post        Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id])
  parent      Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies     Comment[] @relation("CommentReplies")

  @@index([postId, createdAt])  // 按分享和时间索引
  @@index([parentId])           // 按父评论索引（用于查询回复）
}

// 通知表
model Notification {
  id         String    @id @default(cuid())
  receiverId String    // 接收通知的用户 ID
  senderId   String?   // 发送通知的用户 ID（可选）
  type       String    // 通知类型：new_post/comment/pair_accepted
  content    String    // 通知内容
  postId     String?   // 关联的分享 ID
  commentId  String?   // 关联的评论 ID
  isRead     Boolean   @default(false)
  createdAt  DateTime  @default(now())

  receiver   User      @relation("NotificationReceiver", fields: [receiverId], references: [id])
  sender     User?     @relation("NotificationSender", fields: [senderId], references: [id])
  post       Post?     @relation(fields: [postId], references: [id])

  @@index([receiverId, isRead, createdAt])
}

// 支付状态枚举
enum PaymentStatus {
  PENDING    // 待支付
  PAID       // 已支付
  FAILED     // 支付失败
  REFUNDED   // 已退款
}

// 支付订单表
model PaymentOrder {
  id             String        @id @default(cuid())
  outTradeNo     String        @unique  // ZPay 订单号，格式：YYYYMMDDHHmmss + 随机 3 位
  userId         String?       // 用户 ID（如果已登录）
  amount         Decimal       @db.Decimal(10, 2)  // 订单金额
  currency       String        @default("CNY")
  productName    String        // 商品名称（打赏：Buy Me a Coffee）
  paymentType    String        // alipay / wxpay
  status         PaymentStatus @default(PENDING)
  param          String?       // 附加内容（通过 notify_url 原样返回）
  tradeNo        String?       // ZPay 交易号
  paidAt         DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  user           User?         @relation(fields: [userId], references: [id])
  donation       Donation?

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

// 打赏记录表
model Donation {
  id             String        @id @default(cuid())
  orderId        String        @unique
  amount         Decimal       @db.Decimal(10, 2)
  message        String?       // 打赏留言（可选）
  isAnonymous    Boolean       @default(false)  // 是否匿名
  createdAt      DateTime      @default(now())

  paymentOrder   PaymentOrder  @relation(fields: [orderId], references: [id])

  @@index([createdAt])
  @@index([amount])
}
