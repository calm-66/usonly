# 联系邮箱 - 用于接收用户反馈
CONTACT_EMAIL=your-email@example.com

# 网站基础 URL - 用于服务器端构建 API 请求（如 /api/monitor）
# 在 Vercel 中设置为你的生产域名，例如：https://usonly.vercel.app
NEXT_PUBLIC_USONLY_BASE_URL=

# Monitor 配置
# 注意：所有 MONITOR_* 变量都不带 NEXT_PUBLIC_ 前缀，只在服务器端使用

# Monitor API 端点
MONITOR_ENDPOINT=https://xxx/api/events

# Monitor 脚本 URL（这个需要 NEXT_PUBLIC_ 前缀，因为要在客户端加载脚本）
NEXT_PUBLIC_MONITOR_SCRIPT_URL=https://xxx/monitor.js

# 服务器端环境变量（不带 NEXT_PUBLIC_ 前缀）
# 在 Vercel 中设置，不要在 .env 文件中存储敏感信息
MONITOR_PREVIEW_API_KEY=xxx
MONITOR_PRODUCTION_API_KEY=xxx
MONITOR_PREVIEW_PROJECT_ID=xxx
MONITOR_PRODUCTION_PROJECT_ID=xxx

# ZPay 支付配置
# 在 ZPay 平台注册后获取商户 ID 和密钥
ZPAY_PID=your_zpay_pid_here
ZPAY_KEY=your_zpay_key_here

# 支付回调 URL - 需要设置为你的生产环境域名
ZPAY_NOTIFY_URL=https://yourdomain.com/api/payment/notify
ZPAY_RETURN_URL=https://yourdomain.com/api/payment/return

# 网站名称 - 显示在支付页面
SITENAME=UsOnly

# Monitor 支付事件推送配置
MONITOR_API_URL=https://your-monitor-domain.com
MONITOR_API_KEY=your_monitor_api_key_here
