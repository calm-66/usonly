# 数据库连接字符串 (PostgreSQL)
# 在 Vercel 部署时会自动配置
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# 可选：Vercel Postgres 环境变量
# 使用 Vercel Postgres 时会自动设置

# 可选：ImgBB API Key (用于图片上传)
# 获取方式：访问 https://api.imgbb.com/ 注册并获取免费 API Key
# 不配置时，图片将以 Base64 格式存储（不推荐，会增加数据库存储）
NEXT_PUBLIC_IMGBB_API_KEY="your-imgbb-api-key-here"

# 可选：Webhook URL (用于新用户注册通知)
# 本地开发时，使用 ngrok 将本地 3000 端口暴露到公网，然后将此环境变量设置为 ngrok 提供的公网地址
# 配置后，生产环境（Vercel）的新用户注册会发送 Webhook 到本地开发服务器，触发 Windows 本地弹窗通知
# 示例：WEBHOOK_URL="https://abc123.ngrok.io"
# 获取 ngrok：https://ngrok.com/
WEBHOOK_URL="your-ngrok-url-here"
