# 数据库连接字符串 (PostgreSQL)
# 在 Vercel 部署时会自动配置
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# 可选：Vercel Postgres 环境变量
# 使用 Vercel Postgres 时会自动设置

# 可选：ImgBB API Key (用于图片上传)
# 获取方式：访问 https://api.imgbb.com/ 注册并获取免费 API Key
# 不配置时，图片将以 Base64 格式存储（不推荐，会增加数据库存储）
NEXT_PUBLIC_IMGBB_API_KEY="your-imgbb-api-key-here"

# 可选：Vercel Webhook Secret (用于验证 webhook 请求)
# 生成方式：使用 openssl 或在线工具生成随机字符串
# 示例：openssl rand -hex 32
# 不配置时，webhook 将跳过签名验证（仅建议在本地开发时使用）
VERCEL_WEBHOOK_SECRET="your-webhook-secret-here"

# ==================== Monitor 监控服务配置 ====================
# Monitor 项目 ID（在 Monitor 后台创建项目后获取）
NEXT_PUBLIC_MONITOR_PROJECT_ID="your-project-id-here"

# Monitor API Key（用于上报监控数据）
NEXT_PUBLIC_MONITOR_API_KEY="your-api-key-here"

# Monitor 事件上报端点
NEXT_PUBLIC_MONITOR_ENDPOINT="https://monitor-git-dev-calm-66s-projects.vercel.app/api/events"

# Monitor 脚本 URL（可选，默认使用官方 CDN）
NEXT_PUBLIC_MONITOR_SCRIPT_URL="https://monitor-git-dev-calm-66s-projects.vercel.app/monitor.js"
